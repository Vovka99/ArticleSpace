@model ArticleViewModel

@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="text-muted mb-2">
    <span>@Model.Tag</span> |
    <span>@Model.Status</span> |
    <small>@Model.CreatedAt.ToString("g")</small>
</div>

<article>
    @Model.Content
</article>

<p class="mt-3">
    <a asp-controller="Articles" asp-action="Index" class="btn btn-sm btn-secondary">Back</a>
</p>