@model IEnumerable<ArticleViewModel>

@{
	ViewData["Title"] = "Articles";
    
    var query = ViewData["Query"] as string ?? string.Empty;
    var tag = ViewData["Tag"] as string ?? string.Empty;
}

<div class="mb-3">
    <form class="row g-2" method="get" asp-controller="Articles" asp-action="Index" role="search" aria-label="Search articles">
        <div class="col-md-10">
            <div class="input-group">
                <input name="search" type="search" class="form-control form-control-sm" placeholder="Search by title..." value="@query" />
                <input type="text" name="tag" class="form-control form-control-sm" placeholder="Tag" value="@tag" />
                <button class="btn btn-sm btn-primary" type="submit">Search</button>
            </div>
        </div>
        <div class="col-md-2 d-flex">
            @if (!string.IsNullOrEmpty(query) || !string.IsNullOrEmpty(tag))
            {
                <a class="btn btn-outline-secondary btn-sm w-100" href="@Url.Action("Index", "Articles")">Clear</a>
            }
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h5>No articles found</h5>
        <p class="mb-2">Try another search or check back later.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var a in Model)
        {
            <div class="col-12">
                <div class="card card-hover">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title mb-1">@a.Title</h5>
                                <div class="text-muted small mb-2">
                                    <span class="badge badge-tag me-2">@a.Tag</span>
                                    <span class="me-2">@a.Status</span>
                                    <small>@a.CreatedAt.ToString("g")</small>
                                </div>
                            </div>
                            <div>
                                <a class="btn btn-sm btn-link" asp-controller="Articles" asp-action="Details" asp-route-id="@a.Id">Read more</a>
                            </div>
                        </div>

                        <p class="card-text mt-2">@((a.Content?.Length > 280) ? a.Content.Substring(0, 280) + "…" : a.Content)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
