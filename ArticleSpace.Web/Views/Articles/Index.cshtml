@model IEnumerable<ArticleViewModel>

@{
	ViewData["Title"] = "Articles";
    
    var query = ViewData["Query"] as string ?? string.Empty;
    var tag = ViewData["Tag"] as string ?? string.Empty;
}

<h1>@ViewData["Title"]</h1>

<form class="mb-3" method="get" asp-controller="Articles" asp-action="Index">
    <div class="row g-2">
        <div class="col-md-6">
            <input type="search" name="search" class="form-control" placeholder="Search by title..." value="@query" />
        </div>
        <div class="col-md-3">
            <input type="text" name="tag" class="form-control" placeholder="Tag" value="@tag" />
        </div>
        <div class="col-md-3">
            <div class="d-flex">
                <button class="btn btn-primary me-2" type="submit">Search</button>
                @if (!string.IsNullOrEmpty(query) || !string.IsNullOrEmpty(tag))
                {
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Articles")">Clear</a>
                }
            </div>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <p>No articles found.</p>
}
else
{
    <div class="list-group">
        @foreach (var a in Model)
        {
            <div class="list-group-item mb-2">
                <h5>@a.Title</h5>
                <div class="text-muted mb-1">
                    <span>@a.Tag</span> |
                    <span>@a.Status</span> |
                    <small>@a.CreatedAt.ToString("g")</small>
                </div>
                <p>@(a.Content?.Length > 250 ? a.Content.Substring(0, 250) + "…" : a.Content)</p>
                <a class="btn btn-sm btn-link" asp-controller="Articles" asp-action="Details" asp-route-id="@a.Id">Read more</a>
            </div>
        }
    </div>
}
