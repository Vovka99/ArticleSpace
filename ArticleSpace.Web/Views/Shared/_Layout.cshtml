<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Article Space</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArticleSpace.Web.styles.css" asp-append-version="true" />

    <style>
        .card-hover { transition: transform .12s ease, box-shadow .12s ease; }
        .card-hover:hover { transform: translateY(-6px); box-shadow: 0 8px 20px rgba(0,0,0,.08); }
        .img-aspect { width:100%; height:180px; object-fit:contain; background-color:#f8f9fa; display:block; }
        .product-image-large { width:100%; height:420px; object-fit:contain; background-color:#f8f9fa; display:block; }
        .badge-category { background: linear-gradient(90deg,#eef2ff,#eefaf1); color:#0d6efd; font-weight:600; }
        .badge-tag { background:#f1f5f9; color:#495057; }
        .rating-star { color:#f59e0b; font-weight:700; margin-right:.25rem; }
        .page-hero { padding:1.25rem 0; margin-bottom:1.25rem; border-bottom:1px solid rgba(0,0,0,.05); }
        .article-body { line-height:1.65; max-width:75ch; }
        .empty-state { border:1px dashed rgba(0,0,0,.06); padding:2rem; text-align:center; color:#6c757d; background:#fff; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand me-3" asp-area="" asp-controller="Articles" asp-action="Index">Article Space</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Articles" asp-action="Index">Articles</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Products" asp-action="Index">Products</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="page-hero">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>
            </div>
        </div>

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Article Space -
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
